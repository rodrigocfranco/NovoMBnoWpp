# Django
SECRET_KEY=change-me-in-production
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mb_wpp

# Redis (Upstash ou local)
REDIS_URL=redis://localhost:6379

# WhatsApp Cloud API
WHATSAPP_WEBHOOK_SECRET=your-webhook-secret
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v21.0

# Anthropic (fallback LLM)
ANTHROPIC_API_KEY=your-anthropic-key

# GCP Vertex AI (primary LLM)
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-east5
GCP_CREDENTIALS=  # JSON string da service account (opcional — usa ADC no Cloud Run)

# Supabase (Auth + Storage only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Pinecone (RAG via Assistant API)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ASSISTANT_NAME=medbrain

# Tavily (Web Search)
TAVILY_API_KEY=your-tavily-api-key

# PubMed E-utilities (verificação de artigos acadêmicos)
NCBI_API_KEY=           # Opcional: aumenta rate limit de 3 para 10 req/s
NCBI_EMAIL=             # Recomendado pela NCBI para identificação

# PharmaDB (bulas + interações medicamentosas — JWT auth)
PHARMADB_API_KEY=       # Formato: pdb_xxxx — Free: 100 req/dia, Pro: 10k req/dia

# OpenAI (Whisper API — áudio transcription, Epic 3)
OPENAI_API_KEY=your-openai-key

# Langfuse (Observability — Story 7.2)
LANGFUSE_ENABLED=False
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com  # EU: cloud.langfuse.com | US: us.cloud.langfuse.com

# Logging
LOG_LEVEL=INFO
